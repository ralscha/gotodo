{
  "name": "app",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "prebuild": "node ./build-info-env.js",
    "postbuild": "bread-compressor dist/app/browser",
    "lint": "ng lint",
    "serve-dist": "ws --hostname localhost -d dist/app/browser -p 1234 -o --log.format stats",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/router": "22.0.6",
    "@ionic/angular": "8.8.13",
    "ionicons": "8.0.13",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.6",
    "@eslint/js": "10.0.1",
    "@ionic/angular-toolkit": "12.3.0",
    "angular-eslint": "22.0.0",
    "bread-compressor-cli": "4.1.0",
    "eslint": "10.6.0",
    "local-web-server": "5.4.0",
    "prettier": "3.9.4",
    "replace-in-file": "8.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
